APP_NAME="EERC LMS API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Match repo root VITE_SERVER_URL (e.g. http://127.0.0.1:8000)
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# MySQL — create database `eerc_lms` first; set DB_USERNAME / DB_PASSWORD for your server.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eerc_lms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

CORS_ALLOWED_ORIGINS=http://localhost:3030,http://127.0.0.1:3030,http://localhost:3033,http://127.0.0.1:3033,http://localhost:5173,http://127.0.0.1:5173

# User (`public_uid`) used for POST/PATCH LMS endpoints until Sanctum maps the real user.
LMS_ACTOR_PUBLIC_UID=learner-01
